PUTIORR_LISTEN_HOST=127.0.0.1
PUTIORR_LISTEN_PORT=17010
PUTIORR_TARGET_DIR=./downloads
PUTIORR_STATE_PATH=./data/putiorr.sqlite

# Optional. You can leave this empty and connect from the web UI with OAuth.
PUTIORR_PUTIO_TOKEN=
PUTIORR_PUTIO_APP_ID=3270
PUTIORR_PUTIO_FOLDER=putiorr

PUTIORR_WORKERS=4
PUTIORR_POLL_INTERVAL_MS=30000
PUTIORR_CLEANUP_REMOTE_FILES=true
PUTIORR_LIVE_RELOAD=true
