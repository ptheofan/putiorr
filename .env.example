# putiorr local development configuration

PUTIORR_LISTEN_HOST=0.0.0.0
PUTIORR_LISTEN_PORT=9091

# Local state and download paths when running outside Docker.
PUTIORR_STATE_PATH=./data/putiorr.sqlite
PUTIORR_TARGET_DIR=./downloads

# Leave empty and connect from the web UI, or paste a put.io token here.
PUTIORR_PUTIO_TOKEN=
PUTIORR_PUTIO_APP_ID=3270

# Default profile used when no seeded profiles exist.
PUTIORR_PUTIO_FOLDER=putiorr
PUTIORR_DEFAULT_PROFILE_NAME=Default
PUTIORR_DEFAULT_PROFILE_TYPE=custom
PUTIORR_DEFAULT_RPC_PATH=/transmission/rpc

# Optional basic auth for the web UI and Transmission RPC endpoints.
PUTIORR_RPC_USERNAME=
PUTIORR_RPC_PASSWORD=

PUTIORR_WORKERS=4
PUTIORR_POLL_INTERVAL_MS=30000
PUTIORR_CLEANUP_REMOTE_FILES=true
PUTIORR_REFRESH_ON_RPC=false
PUTIORR_LIVE_RELOAD=true
