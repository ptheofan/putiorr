{
  "name": "putiorr",
  "version": "1.9.0",
  "description": "A stable put.io bridge that presents a Transmission RPC interface for Sonarr, Radarr, and the rest of the *arr family.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --watch --disable-warning=ExperimentalWarning src/main.ts",
    "lint": "tsc --noEmit",
    "release:check": "pnpm release:gate",
    "release:create": "node scripts/create-release.ts",
    "release:gate": "node scripts/release-gate.ts",
    "start": "node --disable-warning=ExperimentalWarning src/main.ts",
    "test": "node --disable-warning=ExperimentalWarning --test test/*.test.ts",
    "test:coverage": "node --disable-warning=ExperimentalWarning --test --experimental-test-coverage --test-coverage-include='src/**/*.ts' --test-coverage-lines=90 test/*.test.ts"
  },
  "dependencies": {
    "semver": "^7.8.4"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
